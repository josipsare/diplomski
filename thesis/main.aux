\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Histogram distribucije MAD (srednje apsolutno odstupanje) vrijednosti za ukupno 4862 opservacije poduzeće-godina u razdoblju 2014.\,--\,2024. Svaki stupac predstavlja broj opservacija unutar određenog raspona MAD vrijednosti, pri čemu su stupci obojeni prema razini rizika: zeleno za nizak rizik (MAD $< 1{,}5$), žuto za srednji rizik ($1{,}5 \leq $ MAD $< 2{,}5$), narančasto za visok rizik ($2{,}5 \leq $ MAD $< 4{,}0$) i crveno za kritičan rizik (MAD $\geq 4{,}0$). Zelena isprekidana okomita linija označava prag dobre sukladnosti (MAD $= 1{,}5$), a narančasta isprekidana linija označava prag zabrinjavajućeg odstupanja (MAD $= 2{,}5$). U gornjem desnom kutu prikazane su deskriptivne statistike: ukupan broj opservacija ($n = 4862$), aritmetička sredina (1,28) i medijan (1,27). Distribucija pokazuje da većina poduzeća ima MAD vrijednosti između 0,5 i 2,0, s dugim repom koji se proteže prema višim vrijednostima.}}{9}{figure.caption.5}\protected@file@percent }
\newlabel{fig:mad_histogram}{{2}{9}{Histogram distribucije MAD (srednje apsolutno odstupanje) vrijednosti za ukupno 4862 opservacije poduzeće-godina u razdoblju 2014.\,--\,2024. Svaki stupac predstavlja broj opservacija unutar određenog raspona MAD vrijednosti, pri čemu su stupci obojeni prema razini rizika: zeleno za nizak rizik (MAD $< 1{,}5$), žuto za srednji rizik ($1{,}5 \leq $ MAD $< 2{,}5$), narančasto za visok rizik ($2{,}5 \leq $ MAD $< 4{,}0$) i crveno za kritičan rizik (MAD $\geq 4{,}0$). Zelena isprekidana okomita linija označava prag dobre sukladnosti (MAD $= 1{,}5$), a narančasta isprekidana linija označava prag zabrinjavajućeg odstupanja (MAD $= 2{,}5$). U gornjem desnom kutu prikazane su deskriptivne statistike: ukupan broj opservacija ($n = 4862$), aritmetička sredina (1,28) i medijan (1,27). Distribucija pokazuje da većina poduzeća ima MAD vrijednosti između 0,5 i 2,0, s dugim repom koji se proteže prema višim vrijednostima}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Vremenski trendovi}{10}{subsection.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Vremenski trendovi rezultata hi-kvadrat testa za 442 poduzeća po godinama od 2014.\ do 2024. Plava linija s kružnim markerima prikazuje prosječnu hi-kvadrat vrijednost svih poduzeća za svaku godinu, a zelena isprekidana linija prikazuje medijan. Svijetloplavo zasjenjeno područje oko prosjeka predstavlja raspon jedne standardne devijacije. Crvena vodoravna isprekidana linija označava kritičnu vrijednost hi-kvadrat testa od 15,507 (8 stupnjeva slobode, $\alpha = 0{,}05$), iznad koje odstupanje od Benfordovog zakona postaje statistički značajno. Sivi stupci na pozadini (desna os $y$) prikazuju postotak poduzeća čija je $p$-vrijednost manja od 0,05 u svakoj godini. Vidljiv je strukturni pomak nakon 2019.\ godine: prosječna hi-kvadrat vrijednost porasla je s otprilike 45 u razdoblju 2014.\,--\,2018.\ na 55\,--\,60 u razdoblju 2019.\,--\,2024.}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:chi_trend}{{3}{10}{Vremenski trendovi rezultata hi-kvadrat testa za 442 poduzeća po godinama od 2014.\ do 2024. Plava linija s kružnim markerima prikazuje prosječnu hi-kvadrat vrijednost svih poduzeća za svaku godinu, a zelena isprekidana linija prikazuje medijan. Svijetloplavo zasjenjeno područje oko prosjeka predstavlja raspon jedne standardne devijacije. Crvena vodoravna isprekidana linija označava kritičnu vrijednost hi-kvadrat testa od 15,507 (8 stupnjeva slobode, $\alpha = 0{,}05$), iznad koje odstupanje od Benfordovog zakona postaje statistički značajno. Sivi stupci na pozadini (desna os $y$) prikazuju postotak poduzeća čija je $p$-vrijednost manja od 0,05 u svakoj godini. Vidljiv je strukturni pomak nakon 2019.\ godine: prosječna hi-kvadrat vrijednost porasla je s otprilike 45 u razdoblju 2014.\,--\,2018.\ na 55\,--\,60 u razdoblju 2019.\,--\,2024}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Distribucija rizika}{11}{subsection.3.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Tortni dijagram distribucije rizika za 442 poduzeća, klasificirana prema prosječnoj MAD vrijednosti kroz čitavo promatrano razdoblje 2014.\,--\,2024. Svaki isječak predstavlja jednu kategoriju rizika: zelena boja označava nizak rizik (MAD $< 1{,}5$), žuta srednji rizik ($1{,}5 \leq $ MAD $< 2{,}5$), narančasta visok rizik ($2{,}5 \leq $ MAD $< 4{,}0$) i crvena kritičan rizik (MAD $\geq 4{,}0$). Unutar svakog isječka naveden je postotak i apsolutni broj poduzeća. Najveći udio od 69,0\% (304 poduzeća) spada u kategoriju niskog rizika, dok 30,3\% (134 poduzeća) pripada srednjem riziku. Kategorije visokog i kritičnog rizika čine zanemariv udio ukupnog uzorka.}}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:risk_pie}{{4}{11}{Tortni dijagram distribucije rizika za 442 poduzeća, klasificirana prema prosječnoj MAD vrijednosti kroz čitavo promatrano razdoblje 2014.\,--\,2024. Svaki isječak predstavlja jednu kategoriju rizika: zelena boja označava nizak rizik (MAD $< 1{,}5$), žuta srednji rizik ($1{,}5 \leq $ MAD $< 2{,}5$), narančasta visok rizik ($2{,}5 \leq $ MAD $< 4{,}0$) i crvena kritičan rizik (MAD $\geq 4{,}0$). Unutar svakog isječka naveden je postotak i apsolutni broj poduzeća. Najveći udio od 69,0\% (304 poduzeća) spada u kategoriju niskog rizika, dok 30,3\% (134 poduzeća) pripada srednjem riziku. Kategorije visokog i kritičnog rizika čine zanemariv udio ukupnog uzorka}{figure.caption.7}{}}
